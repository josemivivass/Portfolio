#  Plantilla de variables de entorno del backend.

# ─── Servidor ───
PORT=3000
# Orígenes permitidos por CORS, separados por comas. Vacío = permite todos.
# Ej.: https://tudominio.com,https://www.tudominio.com
CORS_ORIGINS=

# ─── Base de datos MySQL ───
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=portfolio

# ─── Autenticación (JWT) ───
# Clave larga y aleatoria para firmar los tokens.
JWT_SECRET=

# ─── Envío de correos (formulario de contacto) ───
EMAIL_SERVICE=gmail
EMAIL_USER=
# Para Gmail: contraseña de aplicación (no la contraseña normal de la cuenta).
EMAIL_PASS=
# Dirección que recibe los avisos de contacto.
EMAIL_TO=

# ─── reCAPTCHA ───
RECAPTCHA_SECRET=

# ─── Chatbot (API de Groq) ───
AI_API_KEY=

# ─── Backup automático a Google Drive (OAuth2) ───
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET: credenciales OAuth de Google Cloud.
# GOOGLE_REFRESH_TOKEN: se obtiene ejecutando `node scripts/get-drive-token.js`.
# Mientras estas tres estén vacías, el backup automático queda deshabilitado.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Carpeta de Drive donde se guardan los backups (se crea sola si no existe).
GOOGLE_DRIVE_BACKUP_FOLDER=backups
# Nº de backups a conservar; los más antiguos se borran (0 = conservar todos).
GOOGLE_DRIVE_BACKUP_KEEP=100

# Programación del backup (cron). Por defecto: diario a las 03:00.
BACKUP_CRON=0 3 * * *
BACKUP_TZ=Europe/Madrid

# Puerto del servidor local temporal de scripts/get-drive-token.js (opcional).
OAUTH_HELPER_PORT=5273